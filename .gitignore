/target
# `dist/` is built fresh on every CI run by .github/workflows/static.yml, so
# we ignore it locally and don't track it in git.
/dist
# Project-local Python venv used by the asset-generation scripts.
/.venv

# OS / tool junk.
.DS_Store
*.aux.xml
__pycache__/

# Asset generation intermediates. The final, committed assets are the PNGs
# under `crates/app/assets/`; everything else (raw tiles, reprojection
# products, preview renders, scratch dirs) is regeneratable.
/crates/app/assets/tiles/
/crates/app/assets/natural_earth/
/crates/app/assets/swiss.vrt
/crates/app/assets/preview.png
/crates/app/assets/_cities_tmp/
# Raw source data for the biome mask: WWF / RESOLVE Ecoregions (~375MB).
# The committed biome_mask.png is the final product.
/crates/app/assets/wwf/
# Intermediate .tif rasterizations from gdal_rasterize. The .png assets
# next to them are the final committed products.
/crates/app/assets/*.tif
