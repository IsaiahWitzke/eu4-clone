#!/usr/bin/env python3
"""
Generate `crates/app/assets/border_sdf.png` — a signed-distance-field for
province borders.

Pipeline:
  1. Read the clipped NUTS-3 polygons (`crates/app/assets/nuts/nuts3_local.shp`).
  2. Take each polygon's boundary, then `unary_union` them. Union nodes the
     boundaries at every multi-line intersection, so each LineString in the
     result runs from one tri-point (or coast endpoint) to the next. Tri-points
     end up as the LineString endpoints — that's what makes them stay sharp:
     Chaikin smoothing only cuts interior corners, never the endpoints.
  3. Smooth each LineString with Chaikin's corner-cutting algorithm
     (CHAIKIN_ITERATIONS times).
  4. Rasterize the smoothed lines into a `WIDTH × HEIGHT` binary mask using
     Pillow's C-implemented line drawer.
  5. Compute the Euclidean distance transform — at every non-border pixel,
     the distance (in pixels) to the nearest border pixel.
  6. Encode distance / `MAX_DIST_PX` into a uint8 [0, 255] grayscale PNG.
     Anything ≥ MAX_DIST_PX away saturates to 255 (rendered as "no border").

Run from the project root with the project venv:
    ./.venv/bin/python3 script/gen-border-sdf
"""
import json
import os
import subprocess
import sys
import time
from pathlib import Path

import numpy as np
from PIL import Image, ImageDraw
from scipy.ndimage import distance_transform_edt
from shapely.geometry import LineString, MultiLineString, shape
from shapely.ops import unary_union

ROOT = Path(__file__).resolve().parent.parent
INPUT_SHP = ROOT / "crates/app/assets/nuts/nuts3_local.shp"
OUTPUT_PNG = ROOT / "crates/app/assets/border_sdf.png"

# Must match the bbox used when rasterizing province_mask.png and the
# WORLD_BOUNDS_HALF constants in shaders/world.wgsl. Pseudo-Mercator (EPSG:3857).
WORLD_BBOX = (547900.619, 5557277.704, 1174072.754, 6183449.840)
WIDTH = HEIGHT = 8192

CHAIKIN_ITERATIONS = 3   # subdivides each segment 2^N times → 8× refined
MAX_DIST_PX = 48.0       # SDF saturates here; sets the max usable border thickness in shader


def load_geometries(shp_path):
    """Convert shapefile to GeoJSON via ogr2ogr (avoids needing fiona)."""
    print(f"  ogr2ogr → GeoJSON: {shp_path.name}")
    geojson_str = subprocess.check_output([
        "ogr2ogr", "-f", "GeoJSON", "/vsistdout/", str(shp_path),
    ]).decode()
    data = json.loads(geojson_str)
    geoms = [shape(f["geometry"]) for f in data["features"]]
    print(f"    loaded {len(geoms)} polygons")
    return geoms


def collect_boundaries(geometries):
    """
    Take each polygon's boundary (a LineString or MultiLineString for
    polygons-with-holes) and flatten into a list of LineStrings.
    """
    out = []
    for g in geometries:
        b = g.boundary
        if isinstance(b, MultiLineString):
            out.extend(b.geoms)
        elif isinstance(b, LineString):
            out.append(b)
        # else: empty / GeometryCollection — skip
    return out


def chaikin(coords, iterations):
    """
    Chaikin's corner-cutting smoothing. Endpoints are preserved, so when the
    polyline endpoints are tri-points (which is what `unary_union` gives us)
    those stay as sharp corners.

    Each iteration replaces every interior corner with two points at 1/4 and
    3/4 along its incoming/outgoing edges, doubling-ish the vertex count.
    Converges to a quadratic B-spline.
    """
    coords = np.asarray(coords, dtype=np.float64)
    for _ in range(iterations):
        if len(coords) < 3:
            break
        # Vectorised: for every edge (p_i, p_{i+1}), produce two points.
        a = coords[:-1]
        b = coords[1:]
        cuts = np.empty((2 * len(a), 2), dtype=np.float64)
        cuts[0::2] = 0.75 * a + 0.25 * b
        cuts[1::2] = 0.25 * a + 0.75 * b
        coords = np.concatenate([coords[:1], cuts, coords[-1:]])
    return coords


def world_to_pixel(coords, bbox, width, height):
    """
    Map (x, y) world coords (Pseudo-Mercator metres) to (px, py) image coords.
    Image is +X right, +Y down; world is +X right, +Y up — so flip Y.
    """
    xmin, ymin, xmax, ymax = bbox
    px = (coords[:, 0] - xmin) / (xmax - xmin) * width
    py = height - (coords[:, 1] - ymin) / (ymax - ymin) * height
    return np.stack([px, py], axis=1)


def main():
    if not INPUT_SHP.exists():
        sys.exit(f"error: missing {INPUT_SHP}")

    t0 = time.time()
    print(f"Reading {INPUT_SHP}...")
    geometries = load_geometries(INPUT_SHP)

    print("Collecting polygon boundaries...")
    boundaries = collect_boundaries(geometries)
    print(f"  {len(boundaries)} boundary linestrings")

    print("unary_union (nodes shared edges, splits at tri-points)...")
    merged = unary_union(boundaries)
    if isinstance(merged, MultiLineString):
        lines = list(merged.geoms)
    elif isinstance(merged, LineString):
        lines = [merged]
    else:
        lines = []
    print(f"  {len(lines)} unique edge segments after union")

    print(f"Smoothing (Chaikin × {CHAIKIN_ITERATIONS}, endpoints pinned)...")
    smoothed = []
    for ln in lines:
        coords = np.asarray(ln.coords, dtype=np.float64)
        if len(coords) >= 2:
            smoothed.append(chaikin(coords, CHAIKIN_ITERATIONS))
    total_verts = sum(len(c) for c in smoothed)
    print(f"  {total_verts} smoothed vertices total")

    print(f"Rasterizing {WIDTH}×{HEIGHT} binary border mask (Pillow)...")
    img = Image.new("L", (WIDTH, HEIGHT), color=0)
    draw = ImageDraw.Draw(img)
    for coords in smoothed:
        pixels = world_to_pixel(coords, WORLD_BBOX, WIDTH, HEIGHT)
        # Pillow expects a flat list of (x, y) tuples.
        pts = [(int(round(p[0])), int(round(p[1]))) for p in pixels]
        if len(pts) >= 2:
            draw.line(pts, fill=255, width=1)
    mask = np.array(img, dtype=np.uint8)
    print(f"  {int((mask > 0).sum())} border pixels lit")

    print("Computing Euclidean distance transform (this is the slow step)...")
    # distance_transform_edt(input) → distance from each non-zero element to
    # nearest zero. We want distance from each pixel to nearest border, so
    # invert: non-border = 1, border = 0.
    dist_px = distance_transform_edt(mask == 0)

    print(f"Encoding distance / {MAX_DIST_PX}px → uint8 PNG...")
    encoded = np.clip(dist_px / MAX_DIST_PX, 0.0, 1.0) * 255.0
    encoded = encoded.astype(np.uint8)

    OUTPUT_PNG.parent.mkdir(parents=True, exist_ok=True)
    Image.fromarray(encoded, mode="L").save(OUTPUT_PNG, optimize=True)
    size_kb = OUTPUT_PNG.stat().st_size / 1024
    print(f"  wrote {OUTPUT_PNG} ({size_kb:.1f} KiB)")

    print(f"done in {time.time() - t0:.1f}s")


if __name__ == "__main__":
    main()
