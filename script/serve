#!/usr/bin/env bash
# Serve the built dist/ folder over HTTP for local development.
# Usage: ./script/serve [port]
#
# Binds to 127.0.0.1 explicitly so the printed URL works as a secure context
# in browsers. WebGPU (and other secure-context-only APIs) is gated unless the
# origin is localhost / 127.0.0.1 / https — visiting `http://[::]:PORT` or the
# LAN IP will silently disable navigator.gpu in Chrome.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PORT="${1:-8091}"

exec python3 -m http.server --bind 127.0.0.1 --directory "$ROOT/dist" "$PORT"
